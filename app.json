{
  "expo": {
    "name": "BetFree",
    "slug": "bettrmind",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bettrmind",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F1FB"
    },
    "android": {
      "package": "com.bettrmind.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E6F1FB"
      },
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "permissions": [],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bettrmind.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "BetFree uses your photos so you can pick a motivating image to show on the reminder pop-up."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5e07c7eb-1a3b-4a5d-ace4-2e9353dd64d6"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "ardeleonpoultrysupplies"
  }
}
