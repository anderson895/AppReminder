{
  "expo": {
    "name": "BettrMind",
    "slug": "bettrmind",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bettrmind",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "android": {
      "package": "com.bettrmind.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "permissions": []
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bettrmind.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "BettrMind uses your photos so you can pick a motivating image to show on the reminder pop-up."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d3d934e2-03c4-433b-af76-17c55e9e80f9"
      }
    },
    "owner": "masterparj",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
